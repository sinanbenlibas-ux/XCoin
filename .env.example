# Public Reown AppKit project identifier from https://dashboard.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Canonical production origin used for SIWE domain and URI validation
NEXT_PUBLIC_SITE_URL=https://www.xqntcoin.com

# Server-only random secret, at least 32 characters. Never expose or commit it.
XQNT_AUTH_SECRET=

# Official contract; keep empty until the verified Base launch manifest is live.
NEXT_PUBLIC_XQNT_CONTRACT_ADDRESS=

# Read-only launch checks. Never put seed phrases or private keys here.
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=
BASESCAN_API_KEY=

# Public deployment inputs (Base Sepolia first).
DISTRIBUTION_SAFE=
COMMUNITY_SAFE=
LIQUIDITY_SAFE=
TREASURY_SAFE=
TEAM_SAFE=
RESERVE_SAFE=
TEAM_VESTING=
XQNT_TOKEN=
MOCK_USDC=
LAUNCH_TIMESTAMP=
LIQUIDITY_DEADLINE=

# Mainnet release gates; leave blank until evidence exists.
XQNT_MAINNET_ACK=
LEGAL_ENTITY_NAME=
LEGAL_OPINION_SHA256=
AUDIT_REPORT_SHA256=
