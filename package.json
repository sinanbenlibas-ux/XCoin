  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "brand:generate": "node scripts/generate-brand-assets.mjs",
    "contracts:build": "forge build --root contracts",
    "contracts:test": "forge test --root contracts -vv",
    "contracts:surface": "node scripts/check-contract-surface.mjs",
