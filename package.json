    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:sites": "vinext build",
    "test": "npm run build:sites && node --test tests/rendered-html.test.mjs tests/launch-math.test.mjs && tsx --test tests/auth.test.ts",
    "lint": "eslint app tests scripts",
